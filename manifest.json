{
  "manifest_version": 3,
  "name": "Pluck",
  "version": "1.2.0",
  "description": "Hit a hotkey, click any element, and a Claude-Code-ready selector lands on your clipboard.",
  "permissions": ["scripting", "storage"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_title": "Pluck — click an element to copy its selector",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "src/background/service-worker.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "all_frames": true,
      "run_at": "document_idle",
      "js": [
        "src/content/styles.js",
        "src/content/selector.js",
        "src/content/format.js",
        "src/content/inspector.js",
        "src/content/shortcut.js"
      ]
    }
  ]
}
